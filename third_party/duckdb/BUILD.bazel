# Bazel-side glue for the vendored DuckDB. The actual prebuilt
# `libduckdb.so` + headers live inside the `@duckdb_linux_amd64` repo
# that `//MODULE.bazel`'s `http_archive` materializes; this BUILD
# file exposes a stable `//third_party/duckdb:duckdb` label so
# downstream callers (`//backend/storage/duckdb`,
# `//backend/engine/duckdb`, `//binaries/emulator_main`) name a single
# arch-agnostic target instead of reaching into `@duckdb_linux_amd64`
# directly.
#
# `select()` on `@platforms//cpu` picks the prebuilt `libduckdb.so` for
# the target CPU. The engine binary still only ships for linux/amd64
# today (GoogleSQL toolchain); arm64 DuckDB is wired for the in-flight
# native arm64 engine lane.
#
# The prebuilt v1.5.3 tarball pin lives in
# `third_party/duckdb/VERSION`.

load("@rules_cc//cc:defs.bzl", "cc_library")

package(default_visibility = ["//visibility:public"])

cc_library(
    name = "duckdb",
    deps = select({
        "@platforms//cpu:x86_64": ["@duckdb_linux_amd64//:duckdb"],
        "@platforms//cpu:aarch64": ["@duckdb_linux_arm64//:duckdb"],
        "//conditions:default": [":_unsupported_arch"],
    }),
)

# Sentinel that fails the build with a clear message on any CPU we have
# not registered a prebuilt DuckDB zip for.
cc_library(
    name = "_unsupported_arch",
    target_compatible_with = [
        "@platforms//cpu:x86_64",
        "@platforms//cpu:aarch64",
    ],
)
