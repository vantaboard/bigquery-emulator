# bigquery-emulator — CGO/cache env for direnv and Task.
# Resolves sibling ../go-googlesql and ../go-googlesqlite; sources go-googlesql-stack-bootstrap.sh.
#
# Usage (once per clone): direnv allow
# Without direnv: source .envrc before go build / go test, or run via task.

# shellcheck shell=bash
if [ -n "${BASH_SOURCE+x}" ]; then
	_ENVRC_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
else
	_ENVRC_DIR="$(pwd)"
fi
export GO_GOOGLESQL_ROOT="${GO_GOOGLESQL_ROOT:-$(cd "$_ENVRC_DIR/../go-googlesql" && pwd)}"
export GO_GOOGLESQLITE_ROOT="${GO_GOOGLESQLITE_ROOT:-$(cd "$_ENVRC_DIR/../go-googlesqlite" && pwd)}"
# shellcheck disable=SC1091
source "$GO_GOOGLESQL_ROOT/scripts/go-googlesql-stack-bootstrap.sh"

if [ -f "$_ENVRC_DIR/.envrc.local" ]; then
	# shellcheck disable=SC1091
	source "$_ENVRC_DIR/.envrc.local"
fi
