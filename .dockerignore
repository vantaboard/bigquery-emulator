# Keep the docker build context small. Anything not needed by the
# Dockerfile's COPY directives belongs here.

# Reference clone of cloud-spanner-emulator (kept locally for design
# reference; never shipped).
cloud-spanner-emulator/

# Build outputs
bin/
# Allow the two engine artifacts through when the release workflow
# (or anyone passing `--build-arg ENGINE_SOURCE=prebuilt`) has staged
# them on the host. The Dockerfile's `engine-builder-prebuilt` stage
# COPYs these from the build context; the default `bazel` stage
# ignores them.
!bin/emulator_main
!bin/libduckdb.so
build-out/
out/
*.o
*.obj
*.a
*.so
*.dylib
*.dll
*.exe

# Bazel
bazel-*

# CMake out-of-source caches in the source tree.
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
Makefile.cmake

# Go test/profile artifacts.
*.test
*.prof
coverage.out
vendor/

# Editor / OS noise.
.DS_Store
.idea/
.vscode/
*.swp
*~

# Repo metadata not needed inside the image.
.git/
.github/
.cursor/
.cursorignore

# Conformance fixtures + harness aren't needed by the runtime image
# (the Dockerfile copies only the Bazel + Go build inputs explicitly).
conformance/

# Reference googlesql sibling: NEVER ship through the Docker context.
# The engine-builder stage clones the matching upstream tag fresh
# inside the image at /googlesql; including a host sibling here would
# be ambiguous AND blow up the build context by ~1 GiB.
googlesql/

# User-managed dev-environment files (mise/direnv). These are
# intentionally untracked by git and have no business in the image.
.envrc
mise.toml
mise2

# Docs are not needed at build time.
docs/

# The Dockerfile and devcontainer config don't need to be inside the
# image they produce.
Dockerfile
.dockerignore
.devcontainer/
