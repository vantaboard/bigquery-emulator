# Reference clone (kept locally for design reference, never checked in)
cloud-spanner-emulator/

# Build outputs
/bin/
/dist/
/out/
/tmp/
*.o
*.obj
*.a
*.so
*.dylib
*.dll
*.exe

# Bazel workspace symlinks (bazel-bin, bazel-out, bazel-testlogs, ...).
# Leading slash anchors to repo root so this does not accidentally
# match files like `.cursor/rules/bazel-process-hygiene.mdc`.
/bazel-*

# Go
*.test
# Vendored GoogleSQL compliance corpus (not Go test binaries).
!conformance/googlesql-corpus/corpus/
!conformance/googlesql-corpus/corpus/*.test
*.prof
# Repo-root coverage profile that `task coverage:go` and ci.yml write
# next to the Taskfile. Scoped to the root so checked-in fixtures
# like `tools/coverage/testdata/coverage.out` still track.
/coverage.out
vendor/

# Self-hosted coverage pipeline artefacts (regenerated by
# `task coverage:*` and by `.github/workflows/coverage-publish.yml`).
# The summary, baseline, badge JSONs, and the rendered HTML report
# tree all live next to coverage.out under the repo root for local
# inspection; the CI workflow publishes the canonical copies to the
# `gh-pages` branch. None of these belong in the source tree.
/coverage
/coverage.summary.json
/coverage.baseline.json
/coverage.html/

# Editor / OS
.DS_Store
.idea/
*.swp
*~

# Python bytecode caches. Project-wide because first-party Python lives
# under `tools/` (`tools/googlesql-prebuilt/*.py`, `tools/lint/cpp/*.py`)
# and `scripts/` and is invoked by Task / Bazel preflight checks; each
# import populates a `__pycache__/` next to the source. The narrower
# `third_party/**/__pycache__/` rule below is now redundant but kept
# in place to keep the third-party ignore block self-describing.
**/__pycache__/

# Third-party client sample test trees (third_party/<lang>-bigquery-tests/).
# Caches, virtualenvs, vendored sample data, and test runner artifacts that
# any local run of `task thirdparty:*` regenerates. Patterns are scoped so
# they only apply under third_party/ and do not catch repo-owned Python or
# Node sources elsewhere.
third_party/**/__pycache__/
third_party/**/.nox/
third_party/**/.nox-install-tmp/
third_party/**/.venv/
third_party/**/.pytest_cache/
third_party/**/.mypy_cache/
third_party/**/.ruff_cache/
third_party/**/.tox/
third_party/**/*.egg-info/
third_party/**/sponge_log.xml
third_party/**/.coverage
third_party/**/node_modules/
# dbt run logs under third_party/dbt-bigquery-tests (regenerated by
# `task thirdparty:dbt-bigquery-tests`).
third_party/dbt-bigquery-tests/logs/
# Maven build artifacts under third_party/java-bigquery-tests (regenerated by
# `task thirdparty:java-bigquery-tests`). Scoped to third_party/ so a future
# Java tree elsewhere in the repo would not be silently swept up.
third_party/**/target/
third_party/**/*.class
third_party/**/dependency-reduced-pom.xml
third_party/**/.flattened-pom.xml

# Local fake-gcs-server seed mirror populated by
# `task testdata:fake-gcs-sync`. Treated as a cache: large public
# objects, not source. Sync on demand; do not commit.
/testdata/fake-gcs-data/

# Prebuilt GoogleSQL artifact cache populated by
# `task googlesql:fetch-prebuilt`, `task googlesql:stage-bazel`, or
# `task googlesql:stage-fixture`. The unpacked artifact is large
# (header tree + multi-hundred-MB static archives) and reproducible
# from an `(artifact_version, googlesql_sha)` pair, so we never check
# it in. See `.bazelrc` `--config=googlesql-prebuilt` and
# `taskfiles/googlesql.yml` for how it is populated.
/.cache/googlesql-prebuilt/

# Bazel local disk cache (action outputs keyed by content hash).
# Populated automatically by every `bazel build|test|run|coverage`
# under this workspace via the `--disk_cache=.cache/bazel-disk` entry
# in `.bazelrc` (the path is workspace-root-relative; Bazel resolves
# it against the workspace root at invocation time). Typically 6-10
# GiB after a full cold engine build; wipe with `task
# bazel:cache:clear` to reclaim space.
/.cache/bazel-disk/

# Clang-tidy compilation database produced by
# `task lint:cpp:compile-commands` (and consumed by `task lint:cpp:tidy`).
# Regenerated from `bazel aquery`; the file path list embeds absolute
# repo paths and changes whenever the engine's dep graph does.
/compile_commands.json

# bigquery-utils sync scratch (regenerated by scripts/sync_bigquery_utils_udfs.sh).
bqutils-sync.*/
.tmp-genbqutils-*.yaml

# Ad-hoc local log dump (tee'd output from long-running `task thirdparty:*`
# / aggregator / smoke runs, timestamped `<scope>-YYYYMMDD-HHMMSS.log`).
# Regenerated on demand by the operator; useful for post-mortem of a
# specific session but never reproducible across runs, so do not check in.
/.logs/
