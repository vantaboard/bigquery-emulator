/bigquery-emulator
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Dependency directories (remove the comment below to include it)
vendor/
dist

# Python files
__pycache__
.venv

# JetBrains IDE
.idea

# Local direnv overrides — copy from .envrc.local.example; never commit secrets or machine paths
.envrc.local

# Mac files
.DS_Store

# Local Go workspace — cp go.work.dev go.work && go work sync (see go.work.dev)
go.work
go.work.sum

# air (github.com/air-verse/air) build + logs
tmp/

