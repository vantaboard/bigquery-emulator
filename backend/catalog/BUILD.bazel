# Bazel build for the GoogleSQL-facing catalog adapter.
#
# The adapter is the bridge between GoogleSQL's `Catalog` interface
# (which name-resolution / analysis call) and the engine-agnostic
# `backend::storage::Storage` interface (which actually owns the
# dataset/table catalog).
#
# `@googlesql//...` resolves through the `local_path_override` in the
# repo-root `MODULE.bazel`, so a sibling checkout of GoogleSQL
# (`../googlesql/`) is the source of truth for this dep. Bumping
# GoogleSQL = bumping that checkout; no registry hop required.

load("@rules_cc//cc:defs.bzl", "cc_library", "cc_test")
load("//:googlesql_deps.bzl", "GOOGLESQL_SQL_FUNCTION_DEPS", "GOOGLESQL_SQL_TVF_DEPS")

package(default_visibility = ["//visibility:public"])

# `storage_table` is the `googlesql::Table` adapter that wraps an
# entry in the active `Storage`. It is the execution-side counterpart
# of the analysis-only `SimpleTable`s the catalog used to mint;
# subclassing `SimpleTable` keeps the column-list management one
# place so the override is just the `CreateEvaluatorTableIterator`
# factory plus the storage Value -> googlesql Value conversion.
cc_library(
    name = "storage_table",
    srcs = ["storage_table.cc"],
    hdrs = ["storage_table.h"],
    deps = [
        "//backend/schema",
        "//backend/storage",
        "@com_google_absl//absl/status",
        "@com_google_absl//absl/status:statusor",
        "@com_google_absl//absl/strings",
        "@com_google_absl//absl/types:span",
        "@googlesql//googlesql/public:evaluator_table_iterator",
        "@googlesql//googlesql/public:numeric_value",
        "@googlesql//googlesql/public:simple_catalog",
        "@googlesql//googlesql/public:type",
        "@googlesql//googlesql/public:value",
    ],
)

