cc_library(
    name = "googlesql_catalog",
    srcs = ["googlesql_catalog.cc"],
    hdrs = ["googlesql_catalog.h"],
    deps = [
        ":emulator_builtin_extensions",
        ":info_schema_table",
        ":storage_table",
        ":procedure_registry",
        ":tvf_registry",
        ":udf_registry",
        ":view_registry",
        ":wildcard_table",
        "//backend/schema",
        "//backend/storage",
        "@com_google_absl//absl/base:core_headers",
        "@com_google_absl//absl/log",
        "@com_google_absl//absl/status",
        "@com_google_absl//absl/status:statusor",
        "@com_google_absl//absl/strings",
        "@com_google_absl//absl/synchronization",
        "@com_google_absl//absl/types:span",
        # `simple_catalog` transitively re-exports `:type` and the
        # `googlesql/public/types/*` headers (`type_factory`,
        # `struct_type`, ...), which is what the adapter needs. We
        # don't depend on `googlesql/public/types:types` directly
        # because its package restricts visibility to
        # `//googlesql/base:googlesql_implementation`.
        "@googlesql//googlesql/public:builtin_function_options",
        "@googlesql//googlesql/public:catalog",
        "@googlesql//googlesql/public:language_options",
        "@googlesql//googlesql/public:simple_catalog",
        "@googlesql//googlesql/public:type",
    ],
)
